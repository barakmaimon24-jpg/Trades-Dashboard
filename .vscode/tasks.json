{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve dashboard",
      "type": "shell",
      "command": "python -m http.server 5500",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP on",
          "endsPattern": "Press CTRL\\+C"
        }
      }
    }
  ]
}
